# App identifier for both platforms
app_identifier("com.mindmesh.magicalcommunity")

# Apple ID for iOS
apple_id("your-apple-id@example.com") # Replace with your Apple ID

# Team ID for iOS (found in Apple Developer account)
itc_team_id("123456789") # Replace with your App Store Connect Team ID
team_id("8YDZ48SP5U") # Replace with your Development Team ID

# For Android (Google Play Console)
json_key_file("path/to/google-play-service-account.json") # Replace with actual path
package_name("com.mindmesh.magicalcommunity")
